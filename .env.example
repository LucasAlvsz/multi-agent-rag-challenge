# Provedor de embeddings e LLM: openai, bedrock ou gemini
LLM_PROVIDER=openai | bedrock | gemini

# OpenAI (quando LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# AWS Bedrock (quando LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Gemini (quando LLM_PROVIDER=gemini)
GOOGLE_API_KEY=
